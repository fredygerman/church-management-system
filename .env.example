# Root .env.example
# This file shows the structure of the root .env file
# Copy to .env and fill in your values

# Database URL (shared by both apps)
DATABASE_URL=postgresql://user:password@localhost:5432/church_db

# Shared secrets
JWT_SECRET=your-jwt-secret-here-change-in-production
NEXTAUTH_SECRET=your-nextauth-secret-here-change-in-production

# Google OAuth (shared by both apps)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# URLs
API_BASE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

