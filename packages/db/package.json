{
  "name": "@church/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "db:generate": "dotenv drizzle-kit generate",
    "db:push": "dotenv drizzle-kit push",
    "db:migrate": "dotenv tsx migrate.ts",
    "db:seed": "dotenv tsx seed.ts",
    "db:studio": "dotenv drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.7",
    "dotenv": "^17.2.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "drizzle-kit": "^0.30.1",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
