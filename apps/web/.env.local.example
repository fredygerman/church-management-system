# Web .env.local.example
# This file shows the structure of the apps/web/.env.local file
# Copy to apps/web/.env.local and fill in your values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Church Management System

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-change-in-production

# API Configuration
# Internal API URL (used by Next.js server for server-to-server requests)
API_BASE_URL=http://localhost:3001
# Public API URL (used by browser/client)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Google OAuth (must match API)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (optional, only if needed on frontend)
DATABASE_URL=postgresql://user:password@localhost:5432/church_db
